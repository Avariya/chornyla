{
  "name": "chornyla",
  "version": "0.1.0",
  "description": "Convert .docx to G-code for pen plotters using single-stroke Cyrillic handwriting fonts",
  "type": "module",
  "license": "MIT",
  "author": "Oleksii Romanchenko",
  "homepage": "https://avariya.github.io/chornyla/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avariya/chornyla.git"
  },
  "bugs": {
    "url": "https://github.com/Avariya/chornyla/issues"
  },
  "keywords": [
    "plotter",
    "gcode",
    "pen-plotter",
    "single-stroke",
    "hershey",
    "handwriting",
    "docx",
    "cyrillic",
    "ukrainian",
    "grbl"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:update": "UPDATE_SNAPSHOTS=1 vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "docx": "^9.5.0",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "jsdom": "^25.0.1",
    "prettier": "3.4.2",
    "sharp": "^0.33.5",
    "typescript": "5.7.3",
    "typescript-eslint": "8.19.0",
    "vite": "6.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.1"
  }
}
