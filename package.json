{
  "name": "chornyla",
  "version": "0.1.0",
  "description": "Convert .docx to G-code for pen plotters using single-stroke Cyrillic handwriting fonts",
  "type": "module",
  "license": "MIT",
  "author": "Oleksii Romanchenko",
  "homepage": "https://avariya.github.io/chornyla/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avariya/chornyla.git"
  },
  "bugs": {
    "url": "https://github.com/Avariya/chornyla/issues"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "keywords": [
    "plotter",
    "gcode",
    "pen-plotter",
    "single-stroke",
    "hershey",
    "handwriting",
    "docx",
    "cyrillic",
    "ukrainian",
    "grbl"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:update": "UPDATE_SNAPSHOTS=1 vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "docx": "^9.7.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}
