{
  "name": "plotter-handwriting",
  "version": "0.1.0",
  "description": "Convert .docx to G-code for pen plotters using single-stroke Cyrillic fonts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:update": "UPDATE_SNAPSHOTS=1 vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "docx": "^9.5.0",
    "jsdom": "^25.0.1",
    "sharp": "^0.33.5",
    "typescript": "5.7.3",
    "vite": "6.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.1"
  }
}
